    "pages:dev": "npx @cloudflare/next-on-pages && wrangler pages dev"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next": "15.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.11.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3.109.2"
  }
}
